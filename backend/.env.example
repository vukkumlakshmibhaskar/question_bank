# Database Configuration
# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
DATABASE_URL="mysql://root:your_db_password_here@localhost:3306/question_bank"

# App Server Configuration
PORT=5000
NODE_ENV=development
SWAGGER_ENABLED=true

# JWT Authentication Secrets
JWT_ACCESS_SECRET="your_jwt_access_secret_key_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_here"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Gemini AI API Configuration
GEMINI_API_KEY="your_gemini_api_key_here"

# Google Drive Integration - Application-Level Service Account
GOOGLE_CLIENT_EMAIL="your-service-account-client-email@your-project-id.iam.gserviceaccount.com"
# Note: Google private key should contain newline escapes (\n) if placed on a single line, e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvgIBAD.../n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-with-newline-characters-here\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_RAW_FOLDER_ID="your_google_drive_raw_folder_id_here"
GOOGLE_DRIVE_PROCESSED_FOLDER_ID="your_google_drive_processed_folder_id_here"

# Google Drive Integration - User-Level OAuth (Optional / Fallback)
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/uploads/drive/callback"

# Personal Account Workaround (Bypass Service Account 0GB Quota Limit)
# If using a personal @gmail.com account, paste your Google OAuth refresh token here.
# The app will automatically run background tasks on behalf of your personal user account.
GOOGLE_USER_REFRESH_TOKEN="your_personal_user_oauth_refresh_token_here"

# Extraction Integration - existing Python gateway targets
EXTRACTION_STANDARD_API_BASE="http://192.168.1.197:8070"
EXTRACTION_LANGUAGE_API_BASE="http://192.168.1.197:8090"
EXTRACTION_QUESTION_CRAFTER_API_BASE="http://192.168.1.197:8100"
EXTRACTION_PROXY_TIMEOUT_MS=600000
EXTRACTION_STATUS_TIMEOUT_MS=2500
